<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        app:elevation="0dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:navigationIcon="?attr/homeAsUpIndicator"
            app:navigationIconTint="@color/text_primary" />
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="32dp">

            <!-- Dynamic Header Section -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:layout_marginTop="10dp">

                <View
                    android:layout_width="140dp"
                    android:layout_height="140dp"
                    android:layout_gravity="center"
                    android:background="@drawable/glass_circle_bg"
                    android:backgroundTint="#1A2563EB" />

                <com.airbnb.lottie.LottieAnimationView
                    android:id="@+id/lottieLock"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    app:lottie_rawRes="@raw/password_strength"
                    app:lottie_autoPlay="true"
                    app:lottie_loop="true" />
            </FrameLayout>

            <TextView
                android:id="@+id/txtHeaderTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Account Recovery"
                android:textColor="@color/text_primary"
                android:textSize="32sp"
                android:fontFamily="sans-serif-black"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="16dp" />

            <TextView
                android:id="@+id/txtHeaderSubtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Don't worry! We'll help you get back into your account in three easy steps."
                android:textColor="@color/text_secondary"
                android:textSize="15sp"
                android:gravity="center"
                android:layout_marginTop="8dp" />

            <!-- Progress Steps Indicator -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginTop="40dp"
                android:layout_marginBottom="10dp">

                <LinearLayout
                    android:id="@+id/step1_indicator"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">
                    <TextView
                        android:id="@+id/step1_dot"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:background="@drawable/glass_circle_bg"
                        android:backgroundTint="@color/primary"
                        android:text="1"
                        android:gravity="center"
                        android:textColor="@color/white"
                        android:textSize="12sp"
                        android:fontFamily="sans-serif-black"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Email"
                        android:textSize="10sp"
                        android:layout_marginTop="4dp"
                        android:textColor="@color/primary"/>
                </LinearLayout>

                <View
                    android:id="@+id/line1"
                    android:layout_width="40dp"
                    android:layout_height="2dp"
                    android:background="@color/border"
                    android:layout_marginBottom="14dp"/>

                <LinearLayout
                    android:id="@+id/step2_indicator"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">
                    <TextView
                        android:id="@+id/step2_dot"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:background="@drawable/glass_circle_bg"
                        android:backgroundTint="@color/border"
                        android:text="2"
                        android:gravity="center"
                        android:textColor="@color/text_muted"
                        android:textSize="12sp"
                        android:fontFamily="sans-serif-black"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Verify"
                        android:textSize="10sp"
                        android:layout_marginTop="4dp"
                        android:textColor="@color/text_muted"/>
                </LinearLayout>

                <View
                    android:id="@+id/line2"
                    android:layout_width="40dp"
                    android:layout_height="2dp"
                    android:background="@color/border"
                    android:layout_marginBottom="14dp"/>

                <LinearLayout
                    android:id="@+id/step3_indicator"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">
                    <TextView
                        android:id="@+id/step3_dot"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:background="@drawable/glass_circle_bg"
                        android:backgroundTint="@color/border"
                        android:text="3"
                        android:gravity="center"
                        android:textColor="@color/text_muted"
                        android:textSize="12sp"
                        android:fontFamily="sans-serif-black"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Secure"
                        android:textSize="10sp"
                        android:layout_marginTop="4dp"
                        android:textColor="@color/text_muted"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Input Container with soft shadow effect -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp">

                <!-- Step 1: Identity -->
                <LinearLayout
                    android:id="@+id/layoutStep1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="visible">

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Email Address"
                        app:boxCornerRadiusTopStart="16dp" app:boxCornerRadiusTopEnd="16dp" app:boxCornerRadiusBottomStart="16dp" app:boxCornerRadiusBottomEnd="16dp"
                        app:startIconDrawable="@android:drawable/ic_dialog_email"
                        app:startIconTint="@color/primary">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/editIdentity"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@color/text_primary"
                            android:inputType="textEmailAddress"
                            android:fontFamily="sans-serif-medium" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSendOtp"
                        android:layout_width="match_parent"
                        android:layout_height="64dp"
                        android:layout_marginTop="32dp"
                        android:text="Request Security Code"
                        android:textAllCaps="false"
                        android:fontFamily="sans-serif-black"
                        android:textSize="17sp"
                        app:backgroundTint="@color/primary"
                        app:cornerRadius="20dp"
                        app:elevation="4dp" />
                </LinearLayout>

                <!-- Step 2: Verification -->
                <LinearLayout
                    android:id="@+id/layoutStep2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="4-Digit Code"
                        app:boxCornerRadiusTopStart="16dp" app:boxCornerRadiusTopEnd="16dp" app:boxCornerRadiusBottomStart="16dp" app:boxCornerRadiusBottomEnd="16dp">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/editForgotOtp"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@color/text_primary"
                            android:gravity="center"
                            android:inputType="number"
                            android:maxLength="4"
                            android:letterSpacing="1.0"
                            android:textSize="32sp"
                            android:fontFamily="sans-serif-black" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnVerifyForgotOtp"
                        android:layout_width="match_parent"
                        android:layout_height="64dp"
                        android:layout_marginTop="32dp"
                        android:text="Verify &amp; Secure"
                        android:textAllCaps="false"
                        android:fontFamily="sans-serif-black"
                        android:textSize="17sp"
                        app:backgroundTint="@color/success"
                        app:cornerRadius="20dp"
                        app:elevation="4dp" />
                </LinearLayout>

                <!-- Step 3: Password Update -->
                <LinearLayout
                    android:id="@+id/layoutStep3"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="New Password"
                        app:passwordToggleEnabled="true"
                        app:boxCornerRadiusTopStart="16dp" app:boxCornerRadiusTopEnd="16dp" app:boxCornerRadiusBottomStart="16dp" app:boxCornerRadiusBottomEnd="16dp"
                        app:startIconDrawable="@drawable/ic_security_lock"
                        app:startIconTint="@color/primary">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/editNewPassword"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@color/text_primary"
                            android:inputType="textPassword" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:hint="Confirm Password"
                        app:passwordToggleEnabled="true"
                        app:boxCornerRadiusTopStart="16dp" app:boxCornerRadiusTopEnd="16dp" app:boxCornerRadiusBottomStart="16dp" app:boxCornerRadiusBottomEnd="16dp"
                        app:startIconDrawable="@drawable/ic_security_lock"
                        app:startIconTint="@color/primary">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/editConfirmPassword"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@color/text_primary"
                            android:inputType="textPassword" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnUpdatePassword"
                        android:layout_width="match_parent"
                        android:layout_height="64dp"
                        android:layout_marginTop="32dp"
                        android:text="Finalize Reset"
                        android:textAllCaps="false"
                        android:fontFamily="sans-serif-black"
                        android:textSize="17sp"
                        app:backgroundTint="@color/primary"
                        app:cornerRadius="20dp"
                        app:elevation="4dp" />
                </LinearLayout>

            </FrameLayout>

            <TextView
                android:id="@+id/txtBackToLogin"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Return to Sign In"
                android:textColor="@color/primary"
                android:textSize="15sp"
                android:fontFamily="sans-serif-black"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="48dp"
                android:layout_marginBottom="40dp"
                android:onClick="onBackPressed"
                android:clickable="true"
                android:focusable="true" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
