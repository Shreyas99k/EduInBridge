<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        app:elevation="0dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingEnd="16dp">

                <TextView
                    android:id="@+id/toolbarTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:text="EduInBridge"
                    android:textColor="#0F172A"
                    android:textSize="22sp"
                    android:fontFamily="sans-serif-black" />

                <ImageButton
                    android:id="@+id/btnNotifications"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:background="@drawable/glass_circle_bg"
                    android:padding="10dp"
                    android:src="@drawable/ic_notification"
                    app:tint="#64748B" />
            </RelativeLayout>
        </com.google.android.material.appbar.MaterialToolbar>
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Welcome Section -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_alignParentStart="true"
                    android:layout_toStartOf="@id/avatarContainer">

                    <TextView
                        android:id="@+id/txtWelcome"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Welcome Back,"
                        android:textColor="#94A3B8"
                        android:textSize="16sp"
                        android:fontFamily="sans-serif-medium" />

                    <TextView
                        android:id="@+id/txtGreeting"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Shreyas"
                        android:textColor="#0F172A"
                        android:textSize="32sp"
                        android:fontFamily="sans-serif-black" />

                    <TextView
                        android:id="@+id/txtInstitution"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="National Institute of Technology"
                        android:textColor="#64748B"
                        android:textSize="14sp" />
                </LinearLayout>

                <!-- Profile Entry -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/avatarContainer"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardCornerRadius="32dp"
                    app:cardElevation="4dp"
                    app:strokeColor="#6366F1"
                    app:strokeWidth="2dp">
                    <ImageView
                        android:id="@+id/avatar"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="8dp"
                        android:scaleType="centerInside"
                        android:src="@drawable/ic_avatar_modern"
                        app:tint="#6366F1" />
                </com.google.android.material.card.MaterialCardView>
            </RelativeLayout>

            <!-- Stats Row - Darker/Deeper Style -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="3">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    app:cardBackgroundColor="#E0F2FE"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="4dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp"
                        android:gravity="center">
                        <TextView
                            android:id="@+id/rateCleared"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="85%"
                            android:textColor="#0369A1"
                            android:textSize="20sp"
                            android:fontFamily="sans-serif-black" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="SOLVED"
                            android:textColor="#075985"
                            android:textSize="10sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginHorizontal="3dp"
                    app:cardBackgroundColor="#FFEDD5"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="4dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp"
                        android:gravity="center">
                        <TextView
                            android:id="@+id/ratePending"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="15%"
                            android:textColor="#C2410C"
                            android:textSize="20sp"
                            android:fontFamily="sans-serif-black" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="PENDING"
                            android:textColor="#9A3412"
                            android:textSize="10sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    app:cardBackgroundColor="#EDE9FE"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="4dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp"
                        android:gravity="center">
                        <RelativeLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content">
                            <TextView
                                android:id="@+id/txtTotalAskedCount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textColor="#6D28D9"
                                android:textSize="20sp"
                                android:fontFamily="sans-serif-black" />
                        </RelativeLayout>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="TOTAL ASKED"
                            android:textColor="#5B21B6"
                            android:textSize="10sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <!-- Student Alert Area -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardStudentAlert"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="16dp"
                android:visibility="gone"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeWidth="1.5dp"
                app:strokeColor="#F0F9FF"
                app:cardBackgroundColor="#F0F9FF">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">
                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/ic_hub_alerts"
                        android:padding="8dp"
                        android:background="@drawable/glass_circle_bg"
                        android:backgroundTint="#E0F2FE"
                        app:tint="#0284C7" />
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="12dp"
                        android:orientation="vertical">
                        <TextView
                            android:id="@+id/txtStudentAlertTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="New Message"
                            android:textColor="#0369A1"
                            android:textSize="14sp"
                            android:fontFamily="sans-serif-black" />
                        <TextView
                            android:id="@+id/txtStudentAlertSubtitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Your mentor replied to your doubt"
                            android:textColor="#0284C7"
                            android:textSize="12sp"
                            android:fontFamily="sans-serif-medium" />
                    </LinearLayout>
                    <ImageButton
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:src="@drawable/ic_chevron_right"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        app:tint="#0284C7" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Achievement Badges -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="12dp"
                android:text="Your Achievements"
                android:textColor="#0F172A"
                android:textSize="18sp"
                android:fontFamily="sans-serif-black" />

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none">
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingBottom="8dp">

                    <LinearLayout
                        android:id="@+id/badge1"
                        android:layout_width="80dp"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:alpha="0.4">
                        <ImageView
                            android:id="@+id/imgBadge1"
                            android:layout_width="50dp"
                            android:layout_height="50dp"
                            android:src="@drawable/badge_unlocked"
                            app:tint="#94A3B8" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Early Bird"
                            android:textSize="10sp"
                            android:textColor="#64748B"
                            android:layout_marginTop="4dp"
                            android:gravity="center"/>
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/badge2"
                        android:layout_width="80dp"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:layout_marginStart="12dp"
                        android:alpha="0.4">
                        <ImageView
                            android:id="@+id/imgBadge2"
                            android:layout_width="50dp"
                            android:layout_height="50dp"
                            android:src="@drawable/badge_unlocked"
                            app:tint="#94A3B8" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Quick Solver"
                            android:textSize="10sp"
                            android:textColor="#64748B"
                            android:layout_marginTop="4dp"
                            android:gravity="center"/>
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/badge3"
                        android:layout_width="80dp"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:layout_marginStart="12dp"
                        android:alpha="0.4">
                        <ImageView
                            android:id="@+id/imgBadge3"
                            android:layout_width="50dp"
                            android:layout_height="50dp"
                            android:src="@drawable/badge_unlocked"
                            app:tint="#94A3B8" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Pro Learner"
                            android:textSize="10sp"
                            android:textColor="#64748B"
                            android:layout_marginTop="4dp"
                            android:gravity="center"/>
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/badge4"
                        android:layout_width="80dp"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:layout_marginStart="12dp"
                        android:alpha="0.4">
                        <ImageView
                            android:id="@+id/imgBadge4"
                            android:layout_width="50dp"
                            android:layout_height="50dp"
                            android:src="@drawable/badge_unlocked"
                            app:tint="#94A3B8" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Top Peer"
                            android:textSize="10sp"
                            android:textColor="#64748B"
                            android:layout_marginTop="4dp"
                            android:gravity="center"/>
                    </LinearLayout>

                </LinearLayout>
            </HorizontalScrollView>


            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:layout_marginBottom="16dp"
                android:text="Academic Hub"
                android:textColor="#0F172A"
                android:textSize="20sp"
                android:fontFamily="sans-serif-black" />

            <!-- Action Grid - Darker Cards -->
            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="2"
                android:alignmentMode="alignMargins"
                android:columnOrderPreserved="false">

                <!-- Ask Doubt -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardPostDoubt"
                    android:layout_width="0dp"
                    android:layout_height="140dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    app:cardBackgroundColor="#F1F5F9"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="6dp"
                    app:strokeColor="#E2E8F0"
                    app:strokeWidth="1dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="16dp">
                        <ImageView
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:src="@drawable/ic_doubt_modern"
                            app:tint="#2563EB" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="Ask a Doubt"
                            android:textColor="#1E293B"
                            android:textSize="15sp"
                            android:fontFamily="sans-serif-medium" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- My Doubts -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardChatHistory"
                    android:layout_width="0dp"
                    android:layout_height="140dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    app:cardBackgroundColor="#F1F5F9"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="6dp"
                    app:strokeColor="#E2E8F0"
                    app:strokeWidth="1dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="16dp">
                        <ImageView
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:src="@drawable/ic_send_modern"
                            app:tint="#10B981" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="My Doubts"
                            android:textColor="#1E293B"
                            android:textSize="15sp"
                            android:fontFamily="sans-serif-medium" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Mentorship -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardMentorship"
                    android:layout_width="0dp"
                    android:layout_height="140dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    app:cardBackgroundColor="#F1F5F9"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="6dp"
                    app:strokeColor="#E2E8F0"
                    app:strokeWidth="1dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="16dp">
                        <ImageView
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:src="@drawable/ic_avatar_modern"
                            app:tint="#7C3AED" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="Mentorship"
                            android:textColor="#1E293B"
                            android:textSize="15sp"
                            android:fontFamily="sans-serif-medium" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Study Material -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardRepository"
                    android:layout_width="0dp"
                    android:layout_height="140dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    app:cardBackgroundColor="#F1F5F9"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="6dp"
                    app:strokeColor="#E2E8F0"
                    app:strokeWidth="1dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="16dp">
                        <ImageView
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:src="@android:drawable/stat_sys_download"
                            app:tint="#F59E0B" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="Library"
                            android:textColor="#1E293B"
                            android:textSize="15sp"
                            android:fontFamily="sans-serif-medium" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </GridLayout>

            <View android:layout_width="match_parent" android:layout_height="40dp" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
