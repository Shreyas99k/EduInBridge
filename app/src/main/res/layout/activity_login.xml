<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/inner_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:overScrollMode="never">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="32dp">

            <!-- Hero Illustration -->
            <ImageView
                android:id="@+id/headerIllustration"
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:layout_marginTop="20dp"
                android:src="@drawable/ic_edu_insight_logo"
                android:scaleType="centerInside"
                app:layout_constraintTop_toTopOf="parent" />

            <!-- App Name Title -->
            <TextView
                android:id="@+id/appNameTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:textColor="#6366F1"
                android:textSize="44sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="-0.02"
                android:gravity="center"
                app:layout_constraintTop_toBottomOf="@id/headerIllustration" />

            <TextView
                android:id="@+id/welcomeSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Bridging the gap in education"
                android:textColor="#94A3B8"
                android:textSize="16sp"
                android:fontFamily="sans-serif-medium"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/appNameTitle" />

            <!-- Login Form Container -->
            <LinearLayout
                android:id="@+id/loginForm"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="32dp"
                app:layout_constraintTop_toBottomOf="@id/welcomeSubtitle">

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:hint="Email Address"
                    app:boxCornerRadiusTopStart="20dp" app:boxCornerRadiusTopEnd="20dp" app:boxCornerRadiusBottomStart="20dp" app:boxCornerRadiusBottomEnd="20dp"
                    app:boxStrokeColor="#6366F1"
                    app:boxBackgroundColor="#F8FAFC"
                    app:startIconDrawable="@android:drawable/ic_dialog_email"
                    app:startIconTint="#6366F1"
                    app:hintTextColor="#6366F1">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/loginEmail"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="#0F172A"
                        android:inputType="textEmailAddress" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:hint="Password"
                    app:boxCornerRadiusTopStart="20dp" app:boxCornerRadiusTopEnd="20dp" app:boxCornerRadiusBottomStart="20dp" app:boxCornerRadiusBottomEnd="20dp"
                    app:boxStrokeColor="#6366F1"
                    app:boxBackgroundColor="#F8FAFC"
                    app:passwordToggleEnabled="true"
                    app:startIconDrawable="@drawable/ic_security_lock"
                    app:startIconTint="#6366F1"
                    app:hintTextColor="#6366F1">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/loginPassword"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="#0F172A"
                        android:inputType="textPassword" />
                </com.google.android.material.textfield.TextInputLayout>

                <TextView
                    android:id="@+id/txtForgotPassword"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="end"
                    android:layout_marginTop="16dp"
                    android:text="Forgot Password?"
                    android:textColor="#6366F1"
                    android:textStyle="bold" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnLogin"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:layout_marginTop="40dp"
                    android:text="Sign In"
                    android:textAllCaps="false"
                    android:textStyle="bold"
                    android:textSize="18sp"
                    app:backgroundTint="#6366F1"
                    app:cornerRadius="16dp" />

                <TextView
                    android:id="@+id/txtShowSignup"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginTop="24dp"
                    android:text="Create an account"
                    android:textColor="#6366F1"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Role Selection Form -->
            <LinearLayout
                android:id="@+id/roleSelectionForm"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                android:layout_marginTop="40dp"
                app:layout_constraintTop_toBottomOf="@id/welcomeSubtitle">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="I am a..."
                    android:textColor="#0F172A"
                    android:textSize="28sp"
                    android:textStyle="bold" />

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardStudent"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="0dp"
                    app:strokeColor="#6366F1"
                    app:strokeWidth="2dp"
                    android:clickable="true"
                    android:focusable="true">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="20dp" android:gravity="center_vertical" android:orientation="horizontal">
                        <ImageView android:layout_width="40dp" android:layout_height="40dp" android:src="@drawable/ic_avatar_modern" app:tint="#6366F1" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="16dp" android:text="Student" android:textColor="#0F172A" android:textSize="18sp" android:textStyle="bold" />
                        <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1" />
                        <RadioButton android:id="@+id/radioStudent" android:layout_width="wrap_content" android:layout_height="wrap_content" android:clickable="false" android:buttonTint="#6366F1" android:checked="true" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardTeacher"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="0dp"
                    app:strokeColor="#E2E8F0"
                    app:strokeWidth="1dp"
                    android:clickable="true"
                    android:focusable="true">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="20dp" android:gravity="center_vertical" android:orientation="horizontal">
                        <ImageView android:layout_width="40dp" android:layout_height="40dp" android:src="@drawable/ic_home_modern" app:tint="#6366F1" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="16dp" android:text="Mentor" android:textColor="#0F172A" android:textSize="18sp" android:textStyle="bold" />
                        <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1" />
                        <RadioButton android:id="@+id/radioTeacher" android:layout_width="wrap_content" android:layout_height="wrap_content" android:clickable="false" android:buttonTint="#6366F1" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardInstitution"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="0dp"
                    app:strokeColor="#E2E8F0"
                    app:strokeWidth="1dp"
                    android:clickable="true"
                    android:focusable="true">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="20dp" android:gravity="center_vertical" android:orientation="horizontal">
                        <ImageView android:layout_width="40dp" android:layout_height="40dp" android:src="@android:drawable/ic_menu_my_calendar" app:tint="#6366F1" />
                        <TextView android:id="@+id/txtInstitutionLabel" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="16dp" android:text="Institution" android:textColor="#0F172A" android:textSize="18sp" android:textStyle="bold" />
                        <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1" />
                        <RadioButton android:id="@+id/radioInstitution" android:layout_width="wrap_content" android:layout_height="wrap_content" android:clickable="false" android:buttonTint="#6366F1" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnRoleNext"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:layout_marginTop="32dp"
                    android:text="Continue"
                    android:textAllCaps="false"
                    android:textStyle="bold"
                    app:backgroundTint="#6366F1"
                    app:cornerRadius="16dp" />

                <TextView
                    android:id="@+id/txtShowLoginFromRole"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginTop="16dp"
                    android:text="Back to Login"
                    android:textColor="#6366F1"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Register Form Container -->
            <LinearLayout
                android:id="@+id/registerForm"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                android:layout_marginTop="40dp"
                app:layout_constraintTop_toBottomOf="@id/welcomeSubtitle">

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:hint="Full Name"
                    app:boxCornerRadiusTopStart="20dp" app:boxCornerRadiusTopEnd="20dp" app:boxCornerRadiusBottomStart="20dp" app:boxCornerRadiusBottomEnd="20dp"
                    app:boxStrokeColor="#6366F1"
                    app:boxBackgroundColor="#F8FAFC"
                    app:startIconDrawable="@drawable/ic_hub_profile"
                    app:startIconTint="#6366F1"
                    app:hintTextColor="#6366F1">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/regUsername"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="#0F172A"
                        android:inputType="textPersonName" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:hint="Email Address"
                    app:boxCornerRadiusTopStart="20dp" app:boxCornerRadiusTopEnd="20dp" app:boxCornerRadiusBottomStart="20dp" app:boxCornerRadiusBottomEnd="20dp"
                    app:boxStrokeColor="#6366F1"
                    app:boxBackgroundColor="#F8FAFC"
                    app:startIconDrawable="@android:drawable/ic_dialog_email"
                    app:startIconTint="#6366F1"
                    app:hintTextColor="#6366F1">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/regEmail"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="#0F172A"
                        android:inputType="textEmailAddress" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:hint="Mobile Number"
                    app:boxCornerRadiusTopStart="20dp" app:boxCornerRadiusTopEnd="20dp" app:boxCornerRadiusBottomStart="20dp" app:boxCornerRadiusBottomEnd="20dp"
                    app:boxStrokeColor="#6366F1"
                    app:boxBackgroundColor="#F8FAFC"
                    app:startIconDrawable="@android:drawable/ic_menu_call"
                    app:startIconTint="#6366F1"
                    app:hintTextColor="#6366F1">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/regMobile"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="#0F172A"
                        android:inputType="phone" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:hint="Password"
                    app:boxCornerRadiusTopStart="20dp" app:boxCornerRadiusTopEnd="20dp" app:boxCornerRadiusBottomStart="20dp" app:boxCornerRadiusBottomEnd="20dp"
                    app:boxStrokeColor="#6366F1"
                    app:boxBackgroundColor="#F8FAFC"
                    app:passwordToggleEnabled="true"
                    app:startIconDrawable="@drawable/ic_security_lock"
                    app:startIconTint="#6366F1"
                    app:hintTextColor="#6366F1">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/regPassword"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="#0F172A"
                        android:inputType="textPassword" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/layoutRegAddress"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:hint="Institution Address"
                    android:visibility="gone"
                    app:boxCornerRadiusTopStart="20dp" app:boxCornerRadiusTopEnd="20dp" app:boxCornerRadiusBottomStart="20dp" app:boxCornerRadiusBottomEnd="20dp"
                    app:boxStrokeColor="#6366F1"
                    app:boxBackgroundColor="#F8FAFC"
                    app:startIconDrawable="@android:drawable/ic_menu_directions"
                    app:startIconTint="#6366F1"
                    app:hintTextColor="#6366F1">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/regAddress"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="#0F172A"
                        android:inputType="textMultiLine" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/layoutRegInstitution"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:hint="Select Institution"
                    app:boxCornerRadiusTopStart="20dp" app:boxCornerRadiusTopEnd="20dp" app:boxCornerRadiusBottomStart="20dp" app:boxCornerRadiusBottomEnd="20dp"
                    app:boxStrokeColor="#6366F1"
                    app:boxBackgroundColor="#F8FAFC"
                    app:startIconDrawable="@drawable/ic_hub_approvals"
                    app:startIconTint="#6366F1"
                    app:hintTextColor="#6366F1">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/autoCompleteRegInstitution"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="#0F172A"
                        android:focusable="false"
                        android:clickable="true"
                        android:cursorVisible="false" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/layoutRegDepartment"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="24dp"
                    android:hint="Select Department"
                    android:visibility="gone"
                    app:boxCornerRadiusTopStart="20dp" app:boxCornerRadiusTopEnd="20dp" app:boxCornerRadiusBottomStart="20dp" app:boxCornerRadiusBottomEnd="20dp"
                    app:boxStrokeColor="#6366F1"
                    app:boxBackgroundColor="#F8FAFC"
                    app:startIconDrawable="@drawable/ic_courses_modern"
                    app:startIconTint="#6366F1"
                    app:hintTextColor="#6366F1">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/autoCompleteRegDepartment"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="#0F172A"
                        android:focusable="false"
                        android:clickable="true"
                        android:cursorVisible="false" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnFinalRegister"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:text="Join Now"
                    android:textAllCaps="false"
                    android:textStyle="bold"
                    android:textSize="18sp"
                    app:backgroundTint="#6366F1"
                    app:cornerRadius="16dp" />

                <TextView
                    android:id="@+id/btnBackToRole"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginTop="16dp"
                    android:text="Go Back"
                    android:textColor="#6366F1"
                    android:textStyle="bold" />
            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
