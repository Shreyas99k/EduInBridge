<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="8dp"
    app:cardBackgroundColor="#FFFFFF"
    app:cardCornerRadius="20dp"
    app:cardElevation="2dp"
    app:strokeColor="#E2E8F0"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:id="@+id/txtMentorName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Mentor Name"
            android:textColor="#0F172A"
            android:textSize="18sp"
            android:fontFamily="sans-serif-black" />

        <TextView
            android:id="@+id/txtMentorEmail"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="email@example.com"
            android:textColor="#475569"
            android:textSize="13sp"
            android:layout_marginTop="4dp" />

        <TextView
            android:id="@+id/txtMentorMobile"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="+91 0000000000"
            android:textColor="#475569"
            android:textSize="13sp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E2E8F0"
            android:layout_marginVertical="12dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="REGISTERED DEPARTMENT"
            android:textColor="#6366F1"
            android:textSize="10sp"
            android:textStyle="bold"
            android:letterSpacing="0.1" />

        <TextView
            android:id="@+id/txtMentorDepartment"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Not Assigned"
            android:textColor="#0F172A"
            android:textSize="15sp"
            android:layout_marginTop="4dp"
            android:fontFamily="sans-serif-medium" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
