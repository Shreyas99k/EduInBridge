<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        app:elevation="0dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:navigationIcon="?attr/homeAsUpIndicator"
            app:navigationIconTint="#0F172A"
            app:title="Post a Doubt"
            app:titleTextColor="#0F172A" />
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Launch a Doubt"
                android:textColor="#0F172A"
                android:textSize="32sp"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="-0.02" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Connect with our global network of mentors"
                android:textColor="#64748B"
                android:textSize="16sp" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="32dp"
                app:cardElevation="12dp"
                app:strokeColor="#F1F5F9"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="28dp">

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Select Department"
                        android:layout_marginBottom="28dp"
                        app:boxCornerRadiusTopStart="20dp" app:boxCornerRadiusTopEnd="20dp" app:boxCornerRadiusBottomStart="20dp" app:boxCornerRadiusBottomEnd="20dp"
                        app:boxStrokeColor="#6366F1"
                        app:hintTextColor="#6366F1">
                        <AutoCompleteTextView
                            android:id="@+id/spinnerBranch"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:paddingVertical="22dp"
                            android:paddingHorizontal="20dp"
                            android:inputType="none"
                            android:textColor="#0F172A"
                            android:textSize="16sp" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Select Subject"
                        android:layout_marginBottom="28dp"
                        app:boxCornerRadiusTopStart="20dp" app:boxCornerRadiusTopEnd="20dp" app:boxCornerRadiusBottomStart="20dp" app:boxCornerRadiusBottomEnd="20dp"
                        app:boxStrokeColor="#6366F1"
                        app:hintTextColor="#6366F1">
                        <AutoCompleteTextView
                            android:id="@+id/spinnerSubject"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:paddingVertical="22dp"
                            android:paddingHorizontal="20dp"
                            android:inputType="none"
                            android:textColor="#0F172A"
                            android:textSize="16sp" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Preferred Mentor"
                        android:layout_marginBottom="36dp"
                        app:boxCornerRadiusTopStart="20dp" app:boxCornerRadiusTopEnd="20dp" app:boxCornerRadiusBottomStart="20dp" app:boxCornerRadiusBottomEnd="20dp"
                        app:boxStrokeColor="#6366F1"
                        app:hintTextColor="#6366F1">
                        <AutoCompleteTextView
                            android:id="@+id/autoCompleteTeacher"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:paddingVertical="22dp"
                            android:paddingHorizontal="20dp"
                            android:inputType="none"
                            android:textColor="#0F172A"
                            android:textSize="16sp" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="QUERY DETAILS"
                        android:textColor="#94A3B8"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.05"
                        android:layout_marginBottom="16dp" />

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="36dp"
                        app:boxCornerRadiusTopStart="20dp" app:boxCornerRadiusTopEnd="20dp" app:boxCornerRadiusBottomStart="20dp" app:boxCornerRadiusBottomEnd="20dp"
                        app:boxStrokeColor="#6366F1"
                        app:hintTextColor="#6366F1">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/editDoubtDescription"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:minLines="5"
                            android:gravity="top"
                            android:hint="Explain your query in detail..."
                            android:paddingVertical="22dp"
                            android:paddingHorizontal="20dp"
                            android:textColor="#0F172A"
                            android:textSize="16sp" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSubmitDoubt"
                        android:layout_width="match_parent"
                        android:layout_height="64dp"
                        android:text="Post Query"
                        android:textAllCaps="false"
                        android:textStyle="bold"
                        android:textSize="18sp"
                        app:backgroundTint="#2563EB"
                        app:cornerRadius="20dp"
                        app:elevation="4dp" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <View android:layout_width="match_parent" android:layout_height="40dp" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
