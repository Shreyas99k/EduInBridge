<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Outer Glow / Rim Light -->
    <item>
        <shape>
            <stroke android:width="1dp" android:color="#4DFFFFFF" />
            <corners android:radius="24dp" />
        </shape>
    </item>

    <!-- Main Whiteish Glass Surface -->
    <item android:bottom="1dp" android:right="1dp" android:left="1dp" android:top="1dp">
        <shape>
            <gradient
                android:startColor="#26FFFFFF"
                android:centerColor="#1AFFFFFF"
                android:endColor="#0DFFFFFF"
                android:angle="135" />
            <stroke
                android:width="1.2dp"
                android:color="#40FFFFFF" />
            <corners android:radius="24dp" />
        </shape>
    </item>

    <!-- Top Glossy Shine -->
    <item android:left="15dp" android:top="1dp" android:right="15dp" android:bottom="120dp">
        <shape>
            <gradient
                android:startColor="#4DFFFFFF"
                android:endColor="#00FFFFFF"
                android:angle="270" />
            <corners android:radius="24dp" />
        </shape>
    </item>
</layer-list>