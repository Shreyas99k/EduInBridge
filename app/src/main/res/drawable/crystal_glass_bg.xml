<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Outer Soft Glow/Shadow -->
    <item>
        <shape>
            <padding android:bottom="4dp" android:left="4dp" android:right="4dp" android:top="4dp" />
            <solid android:color="#08000000" />
            <corners android:radius="44dp" />
        </shape>
    </item>

    <!-- Main Glass Body -->
    <item>
        <shape>
            <gradient
                android:startColor="#CCFFFFFF"
                android:centerColor="#A6FFFFFF"
                android:endColor="#BFFFFFFF"
                android:angle="135" />
            <stroke
                android:width="1.2dp"
                android:color="#66FFFFFF" />
            <corners android:radius="40dp" />
        </shape>
    </item>

    <!-- Internal Specular Highlight (Top Rim) -->
    <item android:top="1dp" android:left="1dp" android:right="1dp" android:bottom="100dp">
        <shape>
            <gradient
                android:startColor="#E6FFFFFF"
                android:endColor="#00FFFFFF"
                android:angle="270" />
            <corners android:radius="40dp" />
        </shape>
    </item>
</layer-list>
