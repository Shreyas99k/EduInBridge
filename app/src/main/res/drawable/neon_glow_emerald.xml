<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Outer Emerald Glow -->
    <item>
        <shape>
            <padding android:bottom="8dp" android:left="8dp" android:right="8dp" android:top="8dp" />
            <solid android:color="#2600C853" />
            <corners android:radius="60dp" />
        </shape>
    </item>

    <!-- Deep Metallic/Glass Core -->
    <item>
        <shape>
            <gradient
                android:startColor="#CC00C853"
                android:centerColor="#B32E7D32"
                android:endColor="#BF1B5E20"
                android:angle="135" />
            <stroke
                android:width="2dp"
                android:color="#4DFFFFFF" />
            <corners android:radius="52dp" />
        </shape>
    </item>

    <!-- High-Gloss Refraction (Shimmer) -->
    <item android:top="2dp" android:left="20dp" android:right="20dp" android:bottom="90dp">
        <shape>
            <gradient
                android:startColor="#4DFFFFFF"
                android:endColor="#00FFFFFF"
                android:angle="270" />
            <corners android:radius="52dp" />
        </shape>
    </item>
</layer-list>
