<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Outer Neon Bloom -->
    <item>
        <shape>
            <padding
                android:left="12dp"
                android:top="12dp"
                android:right="12dp"
                android:bottom="12dp" />
            <solid android:color="#1A9D7BFF" />
            <corners android:radius="48dp" />
        </shape>
    </item>
    <!-- Glass Rim Glow -->
    <item android:left="2dp" android:top="2dp" android:right="2dp" android:bottom="2dp">
        <shape>
            <gradient
                android:startColor="#E6FFFFFF"
                android:centerColor="#339D7BFF"
                android:endColor="#669D7BFF"
                android:angle="135" />
            <stroke android:width="2.5dp" android:color="#FFFFFF" />
            <corners android:radius="44dp" />
        </shape>
    </item>
</layer-list>
