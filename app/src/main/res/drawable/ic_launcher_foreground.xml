<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Layer 1: The Foundation (Open Book Wings) -->
    <!-- Represents the vast resource of knowledge -->
    <path
        android:pathData="M54,74 C38,74 24,68 24,54 C24,40 38,34 54,34 C70,34 84,40 84,54 C84,68 70,74 54,74 Z"
        android:fillAlpha="0.1"
        android:fillColor="#2563EB" />

    <!-- Layer 2: The Modern Mortarboard (Top of Cap) -->
    <!-- Designed as a sharp, floating rhombus for a tech feel -->
    <path
        android:pathData="M54,18 L88,34 L54,50 L20,34 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="20"
                android:startY="18"
                android:endX="88"
                android:endY="50"
                android:type="linear">
                <item android:offset="0" android:color="#FFFFFF" />
                <item android:offset="1" android:color="#F0F4FF" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Layer 3: The Tassel (Digital Stream) -->
    <path
        android:pathData="M88,34 L88,58 C88,62 84,64 80,64"
        android:strokeWidth="3.5"
        android:strokeLineCap="round"
        android:strokeAlpha="0.8">
        <aapt:attr name="android:strokeColor">
            <gradient
                android:startX="88"
                android:startY="34"
                android:endX="80"
                android:endY="64"
                android:type="linear">
                <item android:offset="0" android:color="#FFFFFF" />
                <item android:offset="1" android:color="#7C3AED" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Layer 4: The "Insight" Lens (Book & Eye Fusion) -->
    <!-- The bottom part of the cap forms an eye/open book -->
    <path
        android:strokeWidth="5"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:pathData="M34,58 C34,72 44,82 54,82 C64,82 74,72 74,58">
        <aapt:attr name="android:strokeColor">
            <gradient
                android:startX="34"
                android:startY="58"
                android:endX="74"
                android:endY="82"
                android:type="linear">
                <item android:offset="0" android:color="#2563EB" />
                <item android:offset="1" android:color="#7C3AED" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Layer 5: The Flame of Knowledge (Central Spark) -->
    <path
        android:pathData="M54,52 L57,60 L54,68 L51,60 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="51"
                android:startY="52"
                android:endX="57"
                android:endY="68"
                android:type="linear">
                <item android:offset="0" android:color="#60A5FA" />
                <item android:offset="1" android:color="#2563EB" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Layer 6: Subtle Geometric Accents -->
    <path
        android:pathData="M54,12 L54,16 M20,34 L16,34 M88,34 L92,34"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="1.5"
        android:strokeAlpha="0.4"
        android:strokeLineCap="round" />

</vector>
