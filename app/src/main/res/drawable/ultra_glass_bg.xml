<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 1. Deep Soft Outer Glow (Ambient) -->
    <item>
        <shape>
            <padding android:bottom="10dp" android:left="10dp" android:right="10dp" android:top="10dp" />
            <solid android:color="#0A000000" />
            <corners android:radius="44dp" />
        </shape>
    </item>

    <!-- 2. Strong Directional Depth Shadow -->
    <item android:left="6dp" android:top="6dp">
        <shape>
            <solid android:color="#12000000" />
            <corners android:radius="44dp" />
        </shape>
    </item>

    <!-- 3. Primary Crystal Surface -->
    <item android:bottom="2dp" android:right="2dp">
        <shape>
            <gradient
                android:angle="135"
                android:centerColor="#D9FFFFFF"
                android:endColor="#B3FFFFFF"
                android:startColor="#F9FFFFFF" />
            <!-- High-Definition Polished Border -->
            <stroke
                android:width="2dp"
                android:color="#FFFFFF" />
            <corners android:radius="44dp" />
        </shape>
    </item>

    <!-- 4. Top Specular Highlight (The "Light Catch") -->
    <item android:bottom="140dp" android:left="25dp" android:right="25dp" android:top="2dp">
        <shape>
            <gradient
                android:angle="270"
                android:endColor="#00FFFFFF"
                android:startColor="#80FFFFFF" />
            <corners android:radius="44dp" />
        </shape>
    </item>

    <!-- 5. Bottom Refraction (Prism Effect) -->
    <item android:top="150dp" android:left="40dp" android:right="40dp" android:bottom="4dp">
        <shape>
            <gradient
                android:angle="90"
                android:endColor="#00FFFFFF"
                android:startColor="#1A9D7BFF" />
            <corners android:radius="44dp" />
        </shape>
    </item>
</layer-list>