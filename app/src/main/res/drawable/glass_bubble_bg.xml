<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Subtle outer glow/shadow -->
    <item>
        <shape>
            <solid android:color="#0DFFFFFF" />
            <corners android:radius="28dp" />
        </shape>
    </item>

    <!-- Main Glassy Surface -->
    <item android:bottom="1dp" android:right="1dp" android:left="1dp" android:top="1dp">
        <shape>
            <gradient
                android:startColor="#1AFFFFFF"
                android:centerColor="#0DFFFFFF"
                android:endColor="#05FFFFFF"
                android:angle="135" />
            <stroke
                android:width="1dp"
                android:color="#26FFFFFF" />
            <corners android:radius="28dp" />
        </shape>
    </item>

    <!-- Glossy Shine Highlight -->
    <item android:left="10dp" android:top="1dp" android:right="10dp" android:bottom="100dp">
        <shape>
            <gradient
                android:startColor="#33FFFFFF"
                android:endColor="#00FFFFFF"
                android:angle="270" />
            <corners android:radius="28dp" />
        </shape>
    </item>
</layer-list>