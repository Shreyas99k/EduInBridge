<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Outer Glow/Shadow -->
    <item>
        <shape>
            <solid android:color="#1A9D7BFF" />
            <corners android:topLeftRadius="24dp" android:bottomLeftRadius="24dp" android:bottomRightRadius="24dp" android:topRightRadius="4dp" />
        </shape>
    </item>
    <!-- Main Glass Body -->
    <item android:left="1dp" android:top="1dp" android:right="1dp" android:bottom="1dp">
        <shape>
            <gradient
                android:startColor="#E69D7BFF"
                android:centerColor="#D98E6BFF"
                android:endColor="#CC7B61FF"
                android:angle="135" />
            <stroke android:width="1.5dp" android:color="#4DFFFFFF" />
            <corners android:topLeftRadius="24dp" android:bottomLeftRadius="24dp" android:bottomRightRadius="24dp" android:topRightRadius="4dp" />
        </shape>
    </item>
</layer-list>
