<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 1. Ambient Depth (Realistic shadow with a hint of purple) -->
    <item android:top="6dp" android:left="6dp">
        <shape>
            <solid android:color="#14000000" />
            <corners android:radius="40dp" />
        </shape>
    </item>

    <!-- 2. Main Crystalline Body -->
    <item android:bottom="2dp" android:right="2dp">
        <shape>
            <gradient
                android:angle="135"
                android:centerColor="#FCFCFF"
                android:endColor="#F2F4FF"
                android:startColor="#FFFFFF" />
            <!-- Polished Precision Border -->
            <stroke
                android:width="1.5dp"
                android:color="#FFFFFF" />
            <corners android:radius="40dp" />
        </shape>
    </item>

    <!-- 3. Internal Rim Highlight (Catching Light) -->
    <item android:bottom="4dp" android:right="4dp" android:top="1.5dp" android:left="1.5dp">
        <shape>
            <stroke
                android:width="1dp"
                android:color="#4DFFFFFF" />
            <corners android:radius="38dp" />
        </shape>
    </item>

    <!-- 4. Subtle Base Diffusion (Bottom Refraction) -->
    <item android:top="140dp" android:left="40dp" android:right="40dp" android:bottom="4dp">
        <shape>
            <gradient
                android:angle="90"
                android:endColor="#00FFFFFF"
                android:startColor="#0D9D7BFF" />
            <corners android:radius="40dp" />
        </shape>
    </item>
</layer-list>