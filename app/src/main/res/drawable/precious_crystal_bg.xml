<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 1. Ambient Glow (Soft Purple shadow) -->
    <item>
        <shape>
            <padding android:bottom="8dp" android:left="8dp" android:right="8dp" android:top="8dp" />
            <solid android:color="#089D7BFF" />
            <corners android:radius="44dp" />
        </shape>
    </item>

    <!-- 2. The Main Frosted Crystal Surface -->
    <item android:bottom="2dp" android:right="2dp">
        <shape>
            <gradient
                android:angle="135"
                android:centerColor="#E6FFFFFF"
                android:endColor="#CCFFFFFF"
                android:startColor="#F9FFFFFF" />
            <!-- The "Diamond-Cut" Precision Edge -->
            <stroke
                android:width="1.2dp"
                android:color="#FFFFFF" />
            <corners android:radius="44dp" />
        </shape>
    </item>

    <!-- 3. Top Specular Shine (Catch-light) -->
    <item android:bottom="140dp" android:left="30dp" android:right="30dp" android:top="1dp">
        <shape>
            <gradient
                android:angle="270"
                android:endColor="#00FFFFFF"
                android:startColor="#B3FFFFFF" />
            <corners android:radius="44dp" />
        </shape>
    </item>

    <!-- 4. Prism Refraction (Subtle Rainbow Edge) -->
    <item android:top="150dp" android:left="40dp" android:right="40dp" android:bottom="4dp">
        <shape>
            <gradient
                android:angle="90"
                android:endColor="#00FFFFFF"
                android:startColor="#0D9D7BFF" />
            <corners android:radius="44dp" />
        </shape>
    </item>
</layer-list>