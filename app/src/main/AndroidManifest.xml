<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.example.eduinsight">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />
    <uses-permission android:name="android.permission.READ_MEDIA_AUDIO" />

    <application
        android:hardwareAccelerated="true"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.EduInsight"
        android:usesCleartextTraffic="true">

        <activity android:name="com.example.eduinsight.SplashActivity" android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name="com.example.eduinsight.LoginActivity"
            android:windowSoftInputMode="adjustResize"
            android:exported="false" />

        <activity android:name="com.example.eduinsight.SignupActivity" android:exported="false" />
        <activity android:name="com.example.eduinsight.ForgotPasswordActivity" android:exported="false" />

        <!-- Role Selection -->
        <activity android:name="com.example.eduinsight.RoleSelectionActivity" android:exported="false" />

        <!-- Dashboards -->
        <activity android:name="com.example.eduinsight.MainStudentDashboardActivity" android:exported="false" />
        <activity android:name="com.example.eduinsight.StudentDashboardActivity" android:exported="false" />
        <activity android:name="com.example.eduinsight.TeacherDashboardActivity" android:exported="false" />
        <activity android:name="com.example.eduinsight.MainTeacherDashboardActivity" android:exported="false" />
        <activity android:name="com.example.eduinsight.InstitutionDashboardActivity" android:exported="false" />

        <!-- Doubt & Mentorship -->
        <activity android:name="com.example.eduinsight.PostDoubtActivity" android:exported="false" />
        <activity android:name="com.example.eduinsight.MyDoubtsActivity" android:exported="false" />
        <activity android:name="com.example.eduinsight.ViewSolutionActivity" android:exported="false" />
        <activity android:name="com.example.eduinsight.MentorshipChatActivity" android:windowSoftInputMode="adjustResize" android:exported="false" />
        <activity android:name="com.example.eduinsight.ViewFullImageActivity" android:exported="false" />

        <!-- Teacher Tools -->
        <activity android:name="com.example.eduinsight.TeacherDoubtListActivity" android:exported="false" />
        <activity android:name="com.example.eduinsight.TeacherMentorshipActivity" android:exported="false" />
        <activity android:name="com.example.eduinsight.TeacherArchiveActivity" android:exported="false" />
        <activity android:name="com.example.eduinsight.TeacherStatsActivity" android:exported="false" />
        <activity android:name="com.example.eduinsight.SolveDoubtActivity" android:exported="false" />
        <activity android:name="com.example.eduinsight.FullChatActivity" android:exported="false" />
        <activity android:name="com.example.eduinsight.AiChatActivity" android:windowSoftInputMode="adjustResize" android:exported="false" />
        <activity android:name="com.example.eduinsight.TeacherApprovalsActivity" android:exported="false" />

        <!-- Curriculum & Management -->
        <activity android:name="com.example.eduinsight.ManageCurriculumActivity" android:exported="false" />
        <activity android:name="com.example.eduinsight.AddCurriculumActivity" android:exported="false" />
        <activity android:name="com.example.eduinsight.ManageMentorsActivity" android:exported="false" />

        <!-- Utilities -->
        <activity android:name="com.example.eduinsight.EditProfileActivity" android:exported="false" />
        <activity android:name="com.example.eduinsight.ChangePasswordActivity" android:exported="false" />
        <activity android:name="com.example.eduinsight.NotificationsActivity" android:exported="false" />
        <activity android:name="com.example.eduinsight.UploadActivity" android:exported="false" />
        <activity android:name="com.example.eduinsight.MaterialListActivity" android:exported="false" />
        <activity android:name="com.example.eduinsight.ProfileActivity" android:exported="false" />
        <activity android:name="com.example.eduinsight.SendNotificationActivity" android:exported="false" />

        <service android:name="com.example.eduinsight.MyFirebaseMessagingService" android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>

    </application>
</manifest>
